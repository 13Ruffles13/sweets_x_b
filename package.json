{
  "name": "sweets_x_b",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "audit": "npm audit",
    "build": "npm run lint && npm run test && tsc -b && vite build && node -e \"console.log('\\n\\u001b[32m✅ BUILD SUCCESSFUL\\u001b[0m\\n')\" || node -e \"console.error('\\n\\u001b[31m❌ BUILD FAILED\\u001b[0m\\n')\"",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "format": "biome format --write .",
    "check": "npm run lint && npm run test",
    "preview": "vite preview",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "fresh-install": "powershell -Command \"Remove-Item -Recurse -Force node_modules; Remove-Item -Force package-lock.json; npm cache clean --force; npx npm-check-updates -u; npm install\"",
    "prepush": "npm run fresh-install && npm run build",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "cypress": "cypress open",
    "cypress:cli": "cypress run"
  },
  "dependencies": {
    "@types/node": "^25.9.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router": "^7.15.1",
    "undici-types": "^8.3.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@eslint/js": "^10.0.1",
    "@html-eslint/eslint-plugin": "^0.61.0",
    "@html-eslint/parser": "^0.61.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/cypress": "^1.1.6",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.7",
    "cypress": "^15.16.0",
    "cypress-axe": "^1.7.0",
    "eslint": "^10.4.0",
    "eslint-plugin-react-dom": "^5.8.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-react-x": "^5.8.5",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "knip": "^6.14.2",
    "prettier": "^3.8.3",
    "react-router-dom": "^7.15.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
