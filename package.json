{
  "name": "sweets_x_b",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run format && npm run lint && npm run test && tsc -b && vite build && node -e \"console.log('\\n\\u001b[32m✅ BUILD SUCCESSFUL\\u001b[0m\\n')\" || node -e \"console.error('\\n\\u001b[31m❌ BUILD FAILED\\u001b[0m\\n')\"",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run && npm run coverage",
    "test:watch": "vitest --watch",
    "coverage": "vitest run --coverage",
    "check": "npm run lint && npm run test",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,scss,md}\"",
    "fresh-install": "powershell -Command \"Remove-Item -Recurse -Force node_modules; Remove-Item -Force package-lock.json; npm cache clean --force; npx npm-check-updates -u; npm install; npm audit\"",
    "prepush": "npm run fresh-install && npm run build",
    "knip": "knip",
    "knip:fix": "knip --fix"
  },
  "dependencies": {
    "@types/node": "^25.0.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-router": "^7.10.1",
    "undici-types": "^7.16.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^4.0.15",
    "autoprefixer": "^10.4.22",
    "eslint": "^9.39.2",
    "eslint-plugin-react-dom": "^2.3.13",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "eslint-plugin-react-x": "^2.3.13",
    "globals": "^16.5.0",
    "jsdom": "^27.3.0",
    "knip": "^5.73.4",
    "postcss": "^8.5.6",
    "prettier": "^3.7.4",
    "react-router-dom": "^7.10.1",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.49.0",
    "vite": "^7.2.7",
    "vitest": "^4.0.15"
  }
}
