{
  "name": "sweets_x_b",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run format && npm run lint && npm run test && tsc -b && vite build && node -e \"console.log('\\n\\u001b[32m✅ BUILD SUCCESSFUL\\u001b[0m\\n')\" || node -e \"console.error('\\n\\u001b[31m❌ BUILD FAILED\\u001b[0m\\n')\"",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run && npm run coverage",
    "test:watch": "vitest --watch",
    "coverage": "vitest run --coverage",
    "check": "npm run lint && npm run test",
    "format": "prettier --write .",
    "fresh-install": "powershell -Command \"Remove-Item -Recurse -Force node_modules; Remove-Item -Force package-lock.json; npm cache clean --force; npx npm-check-updates -u; npm install; npm audit\"",
    "prepush": "npm run fresh-install && npm run build",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "cypress": "cypress open --config-file cypress.config.ts",
    "cypress:cli": "cypress run --config-file cypress.config.ts"
  },
  "dependencies": {
    "@types/node": "^25.0.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-router": "^7.11.0",
    "undici-types": "^7.16.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@html-eslint/eslint-plugin": "^0.52.0",
    "@html-eslint/parser": "^0.52.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^4.0.16",
    "cypress": "^15.8.1",
    "cypress-axe": "^1.7.0",
    "eslint": "^9.39.2",
    "eslint-plugin-react-dom": "^2.4.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "eslint-plugin-react-x": "^2.4.0",
    "globals": "^16.5.0",
    "jsdom": "^27.3.0",
    "knip": "^5.77.1",
    "prettier": "^3.7.4",
    "react-router-dom": "^7.11.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.1",
    "vite": "^7.3.0",
    "vitest": "^4.0.16"
  }
}
