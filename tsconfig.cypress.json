{
  "compilerOptions": {
    "strictNullChecks": true,
    "strict": true,
    "types": ["cypress", "node"],
    "module": "esnext",
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true
  },
  "include": ["cypress/**/*.ts", "cypress.config.ts"],
  "exclude": ["node_modules", "dist", "build", "coverage"]
}
